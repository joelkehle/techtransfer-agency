# Required secrets
OPERATOR_AGENT_SECRET=replace-with-strong-secret
MARKET_EXTRACTOR_AGENT_SECRET=replace-with-strong-secret
MARKET_ANALYSIS_AGENT_SECRET=replace-with-strong-secret
PATENT_EXTRACTOR_AGENT_SECRET=replace-with-strong-secret
PATENT_PIPELINE_INTAKE_SECRET=replace-with-strong-secret
PATENT_PIPELINE_EXTRACTOR_SECRET=replace-with-strong-secret
PATENT_PIPELINE_EVALUATOR_SECRET=replace-with-strong-secret
PATENT_PIPELINE_REPORTER_SECRET=replace-with-strong-secret
PATENT_TEAM_COORDINATOR_SECRET=replace-with-strong-secret
PATENT_TEAM_INTAKE_SECRET=replace-with-strong-secret
PATENT_TEAM_EXTRACTOR_SECRET=replace-with-strong-secret
PATENT_TEAM_PATENT_AGENT_SECRET=replace-with-strong-secret
PATENT_TEAM_REPORTER_SECRET=replace-with-strong-secret
PATENT_SCREEN_AGENT_SECRET=replace-with-strong-secret
PRIOR_ART_AGENT_SECRET=replace-with-strong-secret
PRIOR_ART_EXTRACTOR_AGENT_SECRET=replace-with-strong-secret

# API keys
ANTHROPIC_API_KEY=replace-with-api-key
PATENTSVIEW_API_KEY=replace-with-api-key

# Optional runtime config
PORT=8080
STATE_FILE=/data/state.json
DB_PATH=./bus.db
STORE_BACKEND=memory
# Keep this aligned with *_AGENT_ID values when using strict isolation.
AGENT_ALLOWLIST=tta-operator,tta-patent-extractor,tta-prior-art-extractor,tta-market-extractor,tta-patent-screen,tta-prior-art-search,tta-market-analysis
HUMAN_ALLOWLIST=
DOC_CACHE_PATH=

# Stack isolation / namespacing (recommended)
# Use a unique network name per environment (demo/dev/prod) to isolate bus traffic.
STACK_NETWORK_NAME=tta-agentnet

# Optional host port overrides for parallel stacks on one host
BUS_PORT=8080
OPERATOR_PORT=3000

# Agent IDs (namespaced defaults prevent accidental collisions on a shared bus)
OPERATOR_AGENT_ID=tta-operator
PATENT_EXTRACTOR_AGENT_ID=tta-patent-extractor
PRIOR_ART_EXTRACTOR_AGENT_ID=tta-prior-art-extractor
MARKET_EXTRACTOR_AGENT_ID=tta-market-extractor
PATENT_SCREEN_AGENT_ID=tta-patent-screen
PRIOR_ART_SEARCH_AGENT_ID=tta-prior-art-search
MARKET_ANALYSIS_AGENT_ID=tta-market-analysis
